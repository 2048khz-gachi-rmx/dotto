{
  "Discord": {
    "Token": null,
    "Prefix": ".",
    "AutoDownload": {
      "Patterns": [
        "https?:\\/\\/(?:www\\.)?instagram\\.com\\/reels?\\/[\\w\\-]+",
        "https?:\\/\\/(?:www\\.)?tiktok\\.com\\/.+\\/video\\/\\d+",
        "https?:\\/\\/(?:www\\.)?tiktok\\.com\\/t\\/[\\w\\-]+",
        "https?:\\/\\/vm\\.tiktok\\.com\\/[^\\/]+",
        "https?:\\/\\/x.com\\/[^\\/]+\\/status\\/.+"
      ]
    }
  },
  "UrlCorrection": {
    "Rules": [
      {
        "Patterns": ["^(https?://)?(www\\.)?kkinstagram\\.com"],
        "Replacement": "$1instagram.com"
      }
    ]
  },
  "ConnectionString": "User ID=dotto; Password=dev_only; Host=127.0.0.1; Port=5999; Database=dotto",
  "Downloader": {
    "TempPath": null,
    "CookieFile": null, // Optional Netscape-format cookies file for yt-dlp (--cookies). Docker mounts one at /app/cookies/dotto-ytdlp-cookies.txt

    "Cobalt": {
      "BaseUrl": null,
      "ApiKey": null
    }
  },
  "Minio": {
    "BaseUrl": null, // Set to non-null to enable
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "",
    "Region": ""
  },
  "Compress": {
    "Thresholds": {
      "NeverCompressRatio": 0.9,
      "AlwaysCompressRatio": 0.5,
      "MinimumSavingBytes": 1048576
    },
    "Strategies": {
      "Vp9": {
        "Crf": 35,
        "AudioBitrateKbps": 64
      },
      "Av1": {
        "Crf": 38,
        "AudioBitrateKbps": 64
      }
    },
    "DefaultStrategy": "Av1"
  }
}
